generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMINISTRADOR
  ATENDENTE
  MECANICO
  FINANCEIRO
  ESTOQUE
}

enum TipoPessoa {
  FISICA
  JURIDICA
}

enum Combustivel {
  GASOLINA
  ETANOL
  FLEX
  DIESEL
  GNV
  ELETRICO
  HIBRIDO
}

enum CategoriaServico {
  MECANICA_GERAL
  ELETRONICA_EMBARCADA
  SERVICOS_RAPIDOS
  GEOMETRIA
  CHAPEACAO
  AUTOPECAS
  ACESSORIOS
  FREIOS
  SUSPENSAO
  MOTOR
  ARREFECIMENTO
}

enum StatusOS {
  ABERTA
  AGUARDANDO_DIAGNOSTICO
  AGUARDANDO_APROVACAO
  APROVADA
  EM_EXECUCAO
  AGUARDANDO_PECAS
  CONCLUIDA
  ENTREGUE
  CANCELADA
}

enum PrioridadeOS {
  BAIXA
  NORMAL
  ALTA
  URGENTE
}

enum TipoItem {
  SERVICO
  PECA
}

enum StatusOrcamento {
  RASCUNHO
  ENVIADO
  APROVADO
  REJEITADO
  EXPIRADO
}

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  VEICULO_RECEBIDO
  NAO_COMPARECEU
  CANCELADO
  CONCLUIDO
}

enum StatusItemInspecao {
  OK
  ATENCAO
  CRITICO
  NAO_VERIFICADO
}

enum StatusPagamento {
  PENDENTE
  PARCIAL
  PAGO
  VENCIDO
  CANCELADO
}

enum FormaPagamento {
  PIX
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  TRANSFERENCIA
  BOLETO
  OUTRO
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  AJUSTE
}

enum TipoInteracaoIA {
  RESUMO_OS
  MENSAGEM_WHATSAPP
  EXPLICACAO_ORCAMENTO
  RECOMENDACAO_MANUTENCAO
  RESUMO_INSPECAO
  BUSCA
  OUTRO
}

// ============================================================
// USUÁRIOS E AUTENTICAÇÃO
// ============================================================

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  role            Role     @default(ATENDENTE)
  ativo           Boolean  @default(true)
  telefone        String?
  comissaoPercent Decimal? @default(0) @db.Decimal(5, 2)
  filialId        String?
  filial          Filial?  @relation(fields: [filialId], references: [id], onDelete: SetNull)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ordensResponsavel ServiceOrder[]  @relation("MecanicoOS")
  agendamentos      Appointment[]   @relation("MecanicoAgendamento")
  inspecoes         Inspection[]
  aiInteractions    AiInteraction[]
  timeEntries       TimeEntry[]
  auditLogs         AuditLog[]

  @@index([role])
  @@index([ativo])
  @@index([filialId])
}

// ============================================================
// CLIENTES E VEÍCULOS
// ============================================================

model Customer {
  id          String     @id @default(cuid())
  nome        String
  tipoPessoa  TipoPessoa @default(FISICA)
  cpfCnpj     String?
  telefone    String?
  whatsapp    String?
  email       String?
  endereco    String?
  cidade      String?
  estado      String?
  cep         String?
  observacoes String?    @db.Text
  lgpdConsent Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
  quotes        Quote[]
  appointments  Appointment[]
  portalUser    CustomerUser?
  reviews       Review[]
  reminders     Reminder[]
  sales         Sale[]
  accountsReceivable AccountReceivable[]

  @@index([nome])
  @@index([cpfCnpj])
}

model Vehicle {
  id            String       @id @default(cuid())
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  placa         String
  marca         String
  modelo        String
  ano           Int?
  cor           String?
  quilometragem Int?
  chassi        String?
  renavam       String?
  combustivel   Combustivel?
  observacoes   String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  serviceOrders ServiceOrder[]
  quotes        Quote[]
  appointments  Appointment[]
  inspections   Inspection[]

  @@index([customerId])
  @@index([placa])
}

// ============================================================
// SERVIÇOS
// ============================================================

model Service {
  id               String           @id @default(cuid())
  nome             String
  categoria        CategoriaServico
  descricao        String?          @db.Text
  precoPadrao      Decimal          @default(0) @db.Decimal(10, 2)
  tempoEstimadoMin Int?
  ativo            Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  osItems    ServiceOrderItem[]
  quoteItems QuoteItem[]

  @@index([categoria])
  @@index([ativo])
}

// ============================================================
// FORNECEDORES E PEÇAS / ESTOQUE
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  nome        String
  cnpj        String?
  contato     String?
  telefone    String?
  whatsapp    String?
  email       String?
  endereco    String?
  observacoes String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parts            Part[]
  purchaseOrders   PurchaseOrder[]
  accountsPayable  AccountPayable[]

  @@index([nome])
}

model Part {
  id              String    @id @default(cuid())
  nome            String
  codigoInterno   String    @unique
  categoria       String?
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  precoCusto      Decimal   @default(0) @db.Decimal(10, 2)
  precoVenda      Decimal   @default(0) @db.Decimal(10, 2)
  quantidade      Int       @default(0)
  estoqueMinimo   Int       @default(0)
  localizacao     String?
  compatibilidade String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  movements          InventoryMovement[]
  osItems            ServiceOrderItem[]
  quoteItems         QuoteItem[]
  saleItems          SaleItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([nome])
  @@index([supplierId])
}

// ============================================================
// ORDENS DE SERVIÇO
// ============================================================

model ServiceOrder {
  id               String       @id @default(cuid())
  numero           String       @unique
  customerId       String
  customer         Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicleId        String
  vehicle          Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  mecanicoId       String?
  mecanico         User?        @relation("MecanicoOS", fields: [mecanicoId], references: [id], onDelete: SetNull)
  dataAbertura     DateTime     @default(now())
  quilometragem    Int?
  problemaRelatado String?      @db.Text
  diagnostico      String?      @db.Text
  status           StatusOS     @default(ABERTA)
  prioridade       PrioridadeOS @default(NORMAL)
  previsaoEntrega  DateTime?
  valorMaoObra     Decimal      @default(0) @db.Decimal(10, 2)
  valorPecas       Decimal      @default(0) @db.Decimal(10, 2)
  desconto         Decimal      @default(0) @db.Decimal(10, 2)
  total            Decimal      @default(0) @db.Decimal(10, 2)
  obsInternas      String?      @db.Text
  obsCliente       String?      @db.Text
  trackingToken    String?      @unique
  boxId            String?
  box              Box?         @relation(fields: [boxId], references: [id], onDelete: SetNull)
  filialId         String?
  filial           Filial?      @relation(fields: [filialId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  items              ServiceOrderItem[]
  quotes             Quote[]
  inspections        Inspection[]
  payments           Payment[]
  movements          InventoryMovement[]
  warranties         Warranty[]
  attachments        Attachment[]
  timeEntries        TimeEntry[]
  accountReceivables AccountReceivable[]
  reviews            Review[]
  reminders          Reminder[]
  sales              Sale[]

  @@index([numero])
  @@index([status])
  @@index([customerId])
  @@index([vehicleId])
  @@index([mecanicoId])
  @@index([boxId])
  @@index([filialId])
}

model ServiceOrderItem {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  tipo           TipoItem
  serviceId      String?
  service        Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  partId         String?
  part           Part?        @relation(fields: [partId], references: [id], onDelete: SetNull)
  descricao      String
  quantidade     Int          @default(1)
  precoUnitario  Decimal      @db.Decimal(10, 2)
  custoUnitario  Decimal?     @db.Decimal(10, 2)
  subtotal       Decimal      @db.Decimal(10, 2)

  @@index([serviceOrderId])
  @@index([serviceId])
  @@index([partId])
}

// ============================================================
// ORÇAMENTOS
// ============================================================

model Quote {
  id             String          @id @default(cuid())
  numero         String          @unique
  serviceOrderId String?
  serviceOrder   ServiceOrder?   @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicleId      String
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  status         StatusOrcamento @default(RASCUNHO)
  validade       DateTime?
  desconto       Decimal         @default(0) @db.Decimal(10, 2)
  total          Decimal         @default(0) @db.Decimal(10, 2)
  observacoes    String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items QuoteItem[]

  @@index([numero])
  @@index([status])
  @@index([customerId])
  @@index([vehicleId])
  @@index([serviceOrderId])
}

model QuoteItem {
  id            String   @id @default(cuid())
  quoteId       String
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  tipo          TipoItem
  serviceId     String?
  service       Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  partId        String?
  part          Part?    @relation(fields: [partId], references: [id], onDelete: SetNull)
  descricao     String
  quantidade    Int      @default(1)
  precoUnitario Decimal  @db.Decimal(10, 2)
  subtotal      Decimal  @db.Decimal(10, 2)

  @@index([quoteId])
  @@index([serviceId])
  @@index([partId])
}

// ============================================================
// AGENDA
// ============================================================

model Appointment {
  id              String            @id @default(cuid())
  customerId      String
  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleId       String?
  vehicle         Vehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  mecanicoId      String?
  mecanico        User?             @relation("MecanicoAgendamento", fields: [mecanicoId], references: [id], onDelete: SetNull)
  servicoDesejado String?
  dataHora        DateTime
  duracaoMin      Int               @default(60)
  status          StatusAgendamento @default(AGENDADO)
  observacoes     String?           @db.Text
  boxId           String?
  box             Box?              @relation(fields: [boxId], references: [id], onDelete: SetNull)
  filialId        String?
  filial          Filial?           @relation(fields: [filialId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([dataHora])
  @@index([status])
  @@index([customerId])
  @@index([vehicleId])
  @@index([mecanicoId])
  @@index([boxId])
  @@index([filialId])
}

// ============================================================
// INSPEÇÕES / CHECKLISTS
// ============================================================

model Inspection {
  id             String        @id @default(cuid())
  serviceOrderId String?
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  vehicleId      String
  vehicle        Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  mecanicoId     String?
  mecanico       User?         @relation(fields: [mecanicoId], references: [id], onDelete: SetNull)
  data           DateTime      @default(now())
  observacoes    String?       @db.Text
  resumoIA       String?       @db.Text
  createdAt      DateTime      @default(now())

  items       InspectionItem[]
  attachments Attachment[]

  @@index([serviceOrderId])
  @@index([vehicleId])
  @@index([mecanicoId])
}

model InspectionItem {
  id           String             @id @default(cuid())
  inspectionId String
  inspection   Inspection         @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  item         String
  status       StatusItemInspecao @default(NAO_VERIFICADO)
  observacao   String?            @db.Text

  @@index([inspectionId])
}

// ============================================================
// PAGAMENTOS
// ============================================================

model Payment {
  id             String          @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder    @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  valorTotal     Decimal         @db.Decimal(10, 2)
  valorPago      Decimal         @default(0) @db.Decimal(10, 2)
  forma          FormaPagamento
  status         StatusPagamento @default(PENDENTE)
  dataPagamento  DateTime?
  observacoes    String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([serviceOrderId])
  @@index([status])
}

// ============================================================
// MOVIMENTAÇÃO DE ESTOQUE
// ============================================================

model InventoryMovement {
  id             String           @id @default(cuid())
  partId         String
  part           Part             @relation(fields: [partId], references: [id], onDelete: Cascade)
  tipo           TipoMovimentacao
  quantidade     Int
  motivo         String?
  serviceOrderId String?
  serviceOrder   ServiceOrder?    @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  createdById    String?
  createdAt      DateTime         @default(now())

  @@index([partId])
  @@index([serviceOrderId])
  @@index([tipo])
}

// ============================================================
// GARANTIAS, ANEXOS E IA
// ============================================================

model Warranty {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  descricao      String
  validadeAte    DateTime?
  observacoes    String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([serviceOrderId])
}

model Attachment {
  id             String        @id @default(cuid())
  url            String
  nome           String?
  tipo           String?
  serviceOrderId String?
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  vehicleId      String?
  inspectionId   String?
  inspection     Inspection?   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())

  @@index([serviceOrderId])
  @@index([vehicleId])
  @@index([inspectionId])
}

model AiInteraction {
  id        String          @id @default(cuid())
  userId    String?
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  tipo      TipoInteracaoIA
  input     String          @db.Text
  output    String?         @db.Text
  model     String?
  createdAt DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([tipo, createdAt])
}

// ============================================================
// CONFIGURAÇÕES DA OFICINA
// ============================================================

model WorkshopSettings {
  id        String   @id @default(cuid())
  nome      String
  cnpj      String?
  endereco  String?
  cidade    String?
  estado    String?
  cep       String?
  telefone  String?
  whatsapp  String?
  email     String?
  logoUrl   String?
  horarios  String?  @db.Text
  updatedAt DateTime @updatedAt
}

// ============================================================
// FILIAIS (MULTI-STANDORT)
// ============================================================

model Filial {
  id        String   @id @default(cuid())
  nome      String
  endereco  String?
  cidade    String?
  estado    String?
  telefone  String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  serviceOrders ServiceOrder[]
  appointments  Appointment[]

  @@index([ativo])
}

// ============================================================
// BOXES / ELEVADORES (AGENDA)
// ============================================================

model Box {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrders ServiceOrder[]
  appointments  Appointment[]

  @@index([ativo])
}

// ============================================================
// PORTAL DO CLIENTE
// ============================================================

model CustomerUser {
  id           String   @id @default(cuid())
  customerId   String   @unique
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  email        String   @unique
  passwordHash String
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

// ============================================================
// AVALIAÇÕES / NPS
// ============================================================

model Review {
  id             String        @id @default(cuid())
  serviceOrderId String?
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  nota           Int
  comentario     String?       @db.Text
  createdAt      DateTime      @default(now())

  @@index([serviceOrderId])
  @@index([customerId])
  @@index([nota])
}

// ============================================================
// LEMBRETES
// ============================================================

model Reminder {
  id             String        @id @default(cuid())
  tipo           String
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vehicleId      String?
  serviceOrderId String?
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  dueDate        DateTime
  canal          String?
  status         String        @default("PENDENTE")
  sentAt         DateTime?
  createdAt      DateTime      @default(now())

  @@index([status])
  @@index([dueDate])
  @@index([customerId])
  @@index([serviceOrderId])
}

// ============================================================
// COMPRAS (PURCHASE ORDERS)
// ============================================================

model PurchaseOrder {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  numero      String   @unique
  status      String   @default("RASCUNHO")
  total       Decimal  @default(0) @db.Decimal(10, 2)
  observacoes String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PurchaseOrderItem[]

  @@index([numero])
  @@index([status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  partId          String?
  part            Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)
  descricao       String
  quantidade      Int
  custoUnitario   Decimal       @db.Decimal(10, 2)
  subtotal        Decimal       @db.Decimal(10, 2)

  @@index([purchaseOrderId])
  @@index([partId])
}

// ============================================================
// APONTAMENTO DE HORAS
// ============================================================

model TimeEntry {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  inicio         DateTime
  fim            DateTime?
  minutos        Int?
  observacao     String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([serviceOrderId])
  @@index([userId])
}

// ============================================================
// LOG DE AUDITORIA
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  acao       String
  entidade   String
  entidadeId String?
  detalhe    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entidade, entidadeId])
}

// ============================================================
// FINANCEIRO - CONTAS A PAGAR / RECEBER
// ============================================================

model AccountPayable {
  id            String    @id @default(cuid())
  descricao     String
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  valor         Decimal   @db.Decimal(10, 2)
  vencimento    DateTime
  pago          Boolean   @default(false)
  dataPagamento DateTime?
  createdAt     DateTime  @default(now())

  @@index([pago])
  @@index([vencimento])
  @@index([supplierId])
}

model AccountReceivable {
  id              String        @id @default(cuid())
  descricao       String
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  serviceOrderId  String?
  serviceOrder    ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  valor           Decimal       @db.Decimal(10, 2)
  vencimento      DateTime
  recebido        Boolean       @default(false)
  dataRecebimento DateTime?
  createdAt       DateTime      @default(now())

  @@index([recebido])
  @@index([vencimento])
  @@index([customerId])
  @@index([serviceOrderId])
}

// ============================================================
// FECHAMENTO DE CAIXA
// ============================================================

model CashSession {
  id              String    @id @default(cuid())
  abertura        DateTime  @default(now())
  fechamento      DateTime?
  valorAbertura   Decimal   @default(0) @db.Decimal(10, 2)
  valorFechamento Decimal?  @db.Decimal(10, 2)
  userId          String?
  status          String    @default("ABERTO")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  movements CashMovement[]

  @@index([status])
}

model CashMovement {
  id            String      @id @default(cuid())
  cashSessionId String
  cashSession   CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  tipo          String
  valor         Decimal     @db.Decimal(10, 2)
  descricao     String?
  formaPagamento String?
  createdAt     DateTime    @default(now())

  @@index([cashSessionId])
}

// ============================================================
// PDV / BALCÃO (VENDAS DE AUTOPEÇAS)
// ============================================================

model Sale {
  id             String          @id @default(cuid())
  numero         String          @unique
  customerId     String?
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  serviceOrderId String?
  serviceOrder   ServiceOrder?   @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  total          Decimal         @default(0) @db.Decimal(10, 2)
  formaPagamento FormaPagamento?
  status         String          @default("CONCLUIDA")
  createdAt      DateTime        @default(now())

  items SaleItem[]

  @@index([numero])
  @@index([status])
  @@index([customerId])
  @@index([serviceOrderId])
}

model SaleItem {
  id            String  @id @default(cuid())
  saleId        String
  sale          Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  partId        String?
  part          Part?   @relation(fields: [partId], references: [id], onDelete: SetNull)
  descricao     String
  quantidade    Int
  precoUnitario Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)

  @@index([saleId])
  @@index([partId])
}
