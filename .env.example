# Banco de dados PostgreSQL (Railway, Supabase, Neon ou local)
# Na Railway, referencie o plugin Postgres: DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL="postgresql://usuario:senha@localhost:5432/zimmeros"

# Chave secreta para JWT (gere uma string aleatória forte)
JWT_SECRET="troque-esta-chave-em-producao-com-uma-string-aleatoria-forte"

# OpenAI API Key (opcional — sem ela o app usa respostas-mock)
OPENAI_API_KEY=""

# Modelo de IA (opcional — padrão: gpt-5.4-mini)
OPENAI_MODEL="gpt-5.4-mini"

# SMTP (opcional — sem SMTP_HOST o envio de e-mail roda em modo mock/log)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ZimmerOS <nao-responda@zimmeros>"

# Segredo do cron de avisos (opcional). Quando definido, o endpoint
# /api/cron/reminders só aceita chamadas com o header
# `x-cron-secret: <CRON_SECRET>` ou `Authorization: Bearer <CRON_SECRET>`
# (use em agendadores externos como Railway/cron-job.org). Sem ele, o
# endpoint exige uma sessão de usuário autenticado (acionamento manual).
CRON_SECRET=""

# Ambiente de execução
NODE_ENV="development"

# Fuso horário (em produção/Railway use America/Sao_Paulo p/ datas e horários corretos)
TZ="America/Sao_Paulo"
