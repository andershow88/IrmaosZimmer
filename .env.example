# Banco de dados PostgreSQL (Railway, Supabase, Neon ou local)
DATABASE_URL="postgresql://usuario:senha@localhost:5432/zimmeros"

# Chave secreta para JWT (gere uma string aleatória forte)
JWT_SECRET="troque-esta-chave-em-producao-com-uma-string-aleatoria-forte"

# OpenAI API Key (opcional — sem ela o app usa respostas-mock)
OPENAI_API_KEY=""

# Modelo de IA (opcional — padrão: gpt-5.4-mini)
OPENAI_MODEL="gpt-5.4-mini"

# Ambiente de execução
NODE_ENV="development"
